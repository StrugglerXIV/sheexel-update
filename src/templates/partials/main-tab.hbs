<div class="sheexcel-sidebar-tab tab main active" data-tab="main">
  <div class="sheexcel-main-subtabs">

    <!-- ▷ Subtab Navigation -->
    <nav class="sheexcel-main-subtab-nav tabs" data-group="secondary">
      <a class="item active" data-tab="checks">Checks</a>
      <a class="item" data-tab="abilities">Abilities</a>
      <a class="item" data-tab="saves">Saves</a>
      <a class="item" data-tab="attacks">Attacks</a>
      <a class="item" data-tab="spells">Spells</a>
      <a class="item" data-tab="gears">Gears</a>
      <a class="item" data-tab="rest">Rest</a>
    </nav>

    <!-- ▷ Search Bar -->
    <input class="sheexcel-search" placeholder="Search"></input>

    <!-- ▷ Checks Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="checks" style="display:block;">
      <div class="sheexcel-checks-toolbar">
        <button type="button" class="sheexcel-update-skills-button">Update Skills</button>
      </div>
      <div class="sheexcel-check-dropzone">
        <div class="sheexcel-dropzone-content">
          <span aria-hidden="true">🧩</span>
          <span>Drop checks here to ungroup them</span>
        </div>
      </div>
      
      {{#if groupedReferences.checks.length}}
        <div class="sheexcel-checks-grid">
          {{#each groupedReferences.checks}}
          <div class="sheexcel-check-entry {{#if this.subchecks}}has-children{{/if}}" draggable="true" data-check-id="{{this.id}}"
            data-has-children="{{#if this.subchecks}}true{{else}}false{{/if}}">
            
            <div class="sheexcel-check-main">
              {{#if this.subchecks}}
                <button type="button" class="sheexcel-collapse-toggle" data-check-id="{{this.id}}" title="Toggle subchecks">
                  <span class="sheexcel-collapse-icon">▶</span>
                </button>
              {{/if}}
              
              <button type="button" class="sheexcel-roll" data-value="{{this.value}}" title="Roll {{this.keyword}}">
                <span class="sheexcel-check-keyword">{{this.keyword}}</span>
                <span class="sheexcel-check-value">{{this.value}}</span>
              </button>
              {{#if this.comment}}
              <div class="sheexcel-check-comment">{{this.comment}}</div>
              {{/if}}
            </div>
            
            {{#if this.subchecks}}
            <div class="sheexcel-subchecks">
              {{#each this.subchecks}}
              <div class="sheexcel-check-entry-sub" draggable="true" data-check-id="{{this.id}}">
                <button type="button" class="sheexcel-roll" data-value="{{this.value}}" title="Roll {{this.keyword}}">
                  <span class="sheexcel-check-keyword">{{this.keyword}}</span>
                  <span class="sheexcel-check-value">{{this.value}}</span>
                </button>
                {{#if this.comment}}
                <div class="sheexcel-check-comment">{{this.comment}}</div>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
      {{else}}
        <div class="sheexcel-empty-checks">
          <i>No checks defined</i>
        </div>
      {{/if}}
    </div>

    <!-- ▷ Abilities Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="abilities" style="display:none;">
      <div class="sheexcel-spells-toolbar">
        <button type="button" class="sheexcel-update-abilities-button">Update Abilities</button>
        {{#if groupedReferences.abilities.length}}
        <button type="button" class="sheexcel-abilities-toggle-all" data-state="collapsed">Expand All Abilities</button>
        {{/if}}
      </div>
      {{#if groupedReferences.abilitiesByCategory.length}}
      {{#each groupedReferences.abilitiesByCategory}}
      <div class="sheexcel-spell-circle-group collapsed sheexcel-ability-group">
        <div class="sheexcel-spell-circle-header sheexcel-ability-group-header">
          <span class="sheexcel-spell-circle-toggle-icon">▶</span>
          {{this.label}} <span>({{this.abilities.length}})</span>
        </div>
        <div class="sheexcel-spells-grid sheexcel-abilities-grid">
          {{#each this.abilities}}
          <div class="sheexcel-spell-card sheexcel-ability-card collapsed" data-index="{{this.index}}">
            <div class="sheexcel-spell-header">
              <div class="sheexcel-spell-name">{{#if this.abilityName}}{{this.abilityName}}{{else}}{{this.keyword}}{{/if}}</div>
              <div class="sheexcel-spell-header-actions">
                {{#if this.cost}}
                  <div class="sheexcel-spell-circle">Cost {{this.cost}}</div>
                {{/if}}
                <button type="button" class="sheexcel-spell-toggle sheexcel-ability-toggle" data-action="toggle-ability" title="Expand">
                  <span class="sheexcel-spell-toggle-icon">▶</span>
                </button>
              </div>
            </div>

            <div class="sheexcel-spell-body">
            <div class="sheexcel-spell-tags">
              {{#if this.target}}<span class="sheexcel-spell-tag">Target: {{this.target}}</span>{{/if}}
              {{#if this.range}}<span class="sheexcel-spell-tag">Range: {{this.range}}</span>{{/if}}
              {{#if this.duration}}<span class="sheexcel-spell-tag">Duration: {{this.duration}}</span>{{/if}}
              {{#if this.trigger}}<span class="sheexcel-spell-tag">Trigger: {{this.trigger}}</span>{{/if}}
            </div>

            {{#if this.description}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Description</div>
              <div class="sheexcel-spell-section-text">{{{this.descriptionHtml}}}</div>
            </div>
            {{/if}}

            {{#if this.effect}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Effect</div>
              <div class="sheexcel-spell-section-text">{{{this.effectHtml}}}</div>
            </div>
            {{/if}}

            {{#if this.notes}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Notes</div>
              <div class="sheexcel-spell-section-text">{{{this.notesHtml}}}</div>
            </div>
            {{/if}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{else}}
      <i>No abilities defined</i>
      {{/if}}
    </div>


    <!-- ▷ Saves Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="saves" style="display:none;">
      <div class="sheexcel-saves-toolbar">
        <button type="button" class="sheexcel-update-saves-button">Update Saves</button>
      </div>
      {{#each groupedReferences.saves}}
      <div class="save-button-margin">
        <button type="button" class="sheexcel-roll" data-value="{{this.value}}" data-roll-kind="save">
          {{this.keyword}}
        </button>
        <span class="sheexcel-save-value">{{this.value}}</span>
      </div>
      {{/each}}
      {{#unless groupedReferences.saves.length}}
      <i>No saves defined</i>
      {{/unless}}
    </div>

    <!-- ▷ Attacks Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="attacks" style="display:none;">
      <div class="sheexcel-attacks-toolbar">
        <button type="button" class="sheexcel-update-attacks-button">Update Attacks</button>
      </div>
      <div class="sheexcel-attacks-grid">
        {{#each groupedReferences.attacks}}
        <div class="attack-entry">
          <strong class="attack-name">{{this.attackName}}</strong>
          {{#if this.attackDetail}}
          <div class="attack-detail">({{this.attackDetail}})</div>
          {{/if}}
          {{#if this.comment}}
          <div class="attack-comment">{{this.comment}}</div>
          {{/if}}
          <div class="attack-details">
            <div class="attack-accuracy">
              Accuracy: {{this.accuracyBreakdown}}
            </div>
            <div class="attack-roll-row">
              <button type="button" class="sheexcel-roll sheexcel-attack-card-trigger" data-value="{{this.value}}" data-crit="{{this.critRange}}"
                data-damage="{{this.damage}}" data-damage-type="{{this.damageType}}" data-ref-index="{{this.index}}">
                ROLL
              </button>
              <span class="attack-mod">{{this.value}}</span>
            </div>
            {{#if this.hasMultiDamageParts}}
            <small class="attack-meta muted">Multiple damage parts • Crit on ≥ <code>{{this.critRange}}</code></small>
            <div class="attack-meta damage-parts">
              {{#each this.damageParts}}
              <div class="damage-part"><code>{{this.formula}}</code>{{#if this.type}} <span class="muted">{{this.type}}</span>{{/if}}</div>
              {{/each}}
            </div>
            {{else}}
            <small class="attack-meta">Damage: <code>{{this.damage}}</code>
              {{#if this.damageType}}
               | Type: <code>{{this.damageType}}</code>
              {{/if}}
               | Crit on ≥ <code>{{this.critRange}}</code>
            </small>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>

      {{#unless groupedReferences.attacks.length}}
      <i>No attacks defined</i>
      {{/unless}}
    </div>


    <!-- ▷ Spells Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="spells" style="display:none;">
      <div class="sheexcel-spells-toolbar">
        <button type="button" class="sheexcel-update-spells-button">Update Spells</button>
        {{#if groupedReferences.spells.length}}
        <button type="button" class="sheexcel-spells-toggle-groups" data-state="collapsed">Expand All Circles</button>
        <button type="button" class="sheexcel-spells-toggle-all" data-state="collapsed">Expand All Spells</button>
        {{/if}}
      </div>
      {{#if groupedReferences.spells.length}}
      {{#each groupedReferences.spellsByCircle}}
      <div class="sheexcel-spell-circle-group collapsed">
        <div class="sheexcel-spell-circle-header">
          <span class="sheexcel-spell-circle-toggle-icon">▶</span>
          {{this.label}} <span>({{this.spells.length}})</span>
        </div>
        <div class="sheexcel-spells-grid">
          {{#each this.spells}}
          <div class="sheexcel-spell-card collapsed" data-index="{{this.index}}">
            <div class="sheexcel-spell-header">
              <div class="sheexcel-spell-name">{{#if this.spellName}}{{this.spellName}}{{else}}{{this.keyword}}{{/if}}</div>
              <div class="sheexcel-spell-header-actions">
                {{#if this.circle}}
                  <div class="sheexcel-spell-circle">Circle {{this.circle}}</div>
                {{/if}}
                <button type="button" class="sheexcel-spell-toggle" data-action="toggle-spell" title="Expand">
                  <span class="sheexcel-spell-toggle-icon">▶</span>
                </button>
              </div>
            </div>

            <div class="sheexcel-spell-body">
            <div class="sheexcel-spell-tags">
              {{#if this.spellType}}<span class="sheexcel-spell-tag">{{this.spellType}}</span>{{/if}}
              {{#if this.source}}<span class="sheexcel-spell-tag">{{this.source}}</span>{{/if}}
              {{#if this.discipline}}<span class="sheexcel-spell-tag">{{this.discipline}}</span>{{/if}}
              {{#if this.components}}<span class="sheexcel-spell-tag">Components: {{this.components}}</span>{{/if}}
            </div>

            <div class="sheexcel-spell-stats">
              {{#if this.castTime}}<div><span>Cast</span>{{this.castTime}}</div>{{/if}}
              {{#if this.cost}}<div><span>Cost</span>{{this.cost}}</div>{{/if}}
              {{#if this.range}}<div><span>Range</span>{{this.range}}</div>{{/if}}
              {{#if this.duration}}<div><span>Duration</span>{{this.duration}}</div>{{/if}}
            </div>

            {{#if this.description}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Description</div>
              <div class="sheexcel-spell-section-text">{{{this.descriptionHtml}}}</div>
            </div>
            {{/if}}

            {{#if this.effect}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Effect</div>
              <div class="sheexcel-spell-section-text">{{{this.effectHtml}}}</div>
            </div>
            {{/if}}

            {{#if this.empower}}
            <div class="sheexcel-spell-section">
              <div class="sheexcel-spell-section-title">Empower</div>
              <div class="sheexcel-spell-section-text">{{{this.empowerHtml}}}</div>
            </div>
            {{/if}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{else}}
      <i>No spells defined</i>
      {{/if}}
    </div>

    <!-- ▷ Gears Pane -->
    <div class="sheexcel-main-subtab-content" data-tab="gears" style="display:none;">
      <div class="sheexcel-gears-toolbar">
        <button type="button" class="sheexcel-update-gears-button">Update Gears</button>
        {{#if groupedReferences.gearsByType.length}}
        <button type="button" class="sheexcel-gears-toggle-all-groups" data-state="collapsed">Expand All Groups</button>
        <button type="button" class="sheexcel-gears-toggle-all-cards" data-state="collapsed">Expand All Items</button>
        {{/if}}
      </div>
      {{#if gearCurrency}}
      <div class="sheexcel-gear-currency">
        <div class="sheexcel-gear-currency-block">
          <div class="sheexcel-gear-currency-title">On Person</div>
          <div class="sheexcel-gear-currency-values">
            {{#if gearCurrency.onPerson.gold}}<span class="sheexcel-gear-currency-item">Gold: {{gearCurrency.onPerson.gold}}</span>{{/if}}
            {{#if gearCurrency.onPerson.silver}}<span class="sheexcel-gear-currency-item">Silver: {{gearCurrency.onPerson.silver}}</span>{{/if}}
            {{#if gearCurrency.onPerson.copper}}<span class="sheexcel-gear-currency-item">Copper: {{gearCurrency.onPerson.copper}}</span>{{/if}}
          </div>
        </div>
        <div class="sheexcel-gear-currency-block">
          <div class="sheexcel-gear-currency-title">Banked</div>
          <div class="sheexcel-gear-currency-values">
            {{#if gearCurrency.banked.gold}}<span class="sheexcel-gear-currency-item">Gold: {{gearCurrency.banked.gold}}</span>{{/if}}
            {{#if gearCurrency.banked.silver}}<span class="sheexcel-gear-currency-item">Silver: {{gearCurrency.banked.silver}}</span>{{/if}}
            {{#if gearCurrency.banked.copper}}<span class="sheexcel-gear-currency-item">Copper: {{gearCurrency.banked.copper}}</span>{{/if}}
          </div>
        </div>
      </div>
      {{/if}}
      {{#if groupedReferences.gearsByType.length}}
      {{#each groupedReferences.gearsByType}}
      <div class="sheexcel-gear-type-group collapsed">
        <div class="sheexcel-gear-type-header" data-action="toggle-gear-group">
          <span class="sheexcel-gear-type-collapse-icon">▶</span>
          {{this.label}}
          <span class="sheexcel-gear-type-count">({{this.gears.length}})</span>
        </div>
        <div class="sheexcel-gears-grid">
          {{#each this.gears}}
          <div class="sheexcel-gear-card collapsed" data-index="{{this.index}}">
            <div class="sheexcel-gear-header">
              <div class="sheexcel-gear-name">
                {{#if this.quantity}}<span class="sheexcel-gear-qty">{{this.quantity}}</span>{{/if}}
                {{this.gearName}}
              </div>
              <div class="sheexcel-gear-header-actions">
                <button type="button" class="sheexcel-gear-toggle" data-action="toggle-gear" title="Expand">
                  <span class="sheexcel-gear-toggle-icon">▶</span>
                </button>
              </div>
            </div>

            <div class="sheexcel-gear-body">
              {{#if this.gearType}}<div class="sheexcel-gear-attribute"><span class="sheexcel-gear-label">Type:</span> {{this.gearType}}</div>{{/if}}
              {{#if this.value}}<div class="sheexcel-gear-attribute"><span class="sheexcel-gear-label">Value:</span> {{this.value}}</div>{{/if}}
              {{#if this.weight}}<div class="sheexcel-gear-attribute"><span class="sheexcel-gear-label">Weight:</span> {{this.weight}}</div>{{/if}}
              {{#if this.bulk}}<div class="sheexcel-gear-attribute"><span class="sheexcel-gear-label">Bulk:</span> {{this.bulk}}</div>{{/if}}

              {{#if this.description}}
              <div class="sheexcel-gear-section">
                <div class="sheexcel-gear-section-title">Description</div>
                <div class="sheexcel-gear-section-text">{{{this.gearDescriptionHtml}}}</div>
              </div>
              {{/if}}

              {{#if this.abilities}}
              <div class="sheexcel-gear-section">
                <div class="sheexcel-gear-section-title">Abilities</div>
                <div class="sheexcel-gear-abilities-list">{{{this.gearAbilitiesHtml}}}</div>
              </div>
              {{/if}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{else}}
      <i>No gears defined</i>
      {{/if}}
    </div>

    {{> "modules/sheexcel_updated/templates/partials/rest-tab.hbs"}}
</div>
</div>