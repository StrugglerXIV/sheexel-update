<div class="sheexcel-sidebar-tab tab references" data-tab="references">
  <div class="sheexcel-tab-header">
    <h3>🧰 Configuration</h3>
    <div class="sheexcel-tab-actions">
      <button type="button" class="sheexcel-update-all-button">Update All</button>
      <button type="button" class="sheexcel-clear-checks-button sheexcel-secondary-btn" title="Delete all check references">
        🗑 Clear Checks
      </button>
      <button type="button" class="sheexcel-clear-saves-button sheexcel-secondary-btn" title="Delete all save references">
        🗑 Clear Saves
      </button>
      <button type="button" class="sheexcel-clear-attacks-button sheexcel-secondary-btn" title="Delete all attack references">
        🗑 Clear Attacks
      </button>
      <button type="button" class="sheexcel-clear-spells-button sheexcel-secondary-btn" title="Delete all spell references">
        🗑 Clear Spells
      </button>
      <button type="button" class="sheexcel-clear-abilities-button sheexcel-secondary-btn" title="Delete all ability references">
        🗑 Clear Abilities
      </button>
      <button type="button" class="sheexcel-clear-gears-button sheexcel-secondary-btn" title="Delete all gear references">
        🗑 Clear Gears
      </button>
      <button type="button" class="sheexcel-import-json" title="Import references from JSON file">
        📁 Import
      </button>
      <button type="button" class="sheexcel-export-json" title="Export references to JSON file">
        💾 Export
      </button>
    </div>
  </div>

  <input type="file" id="sheexcel-json-file" accept="application/json" style="display:none;">

  <div class="sheexcel-empty-state">
    <div class="sheexcel-empty-icon">🧹</div>
    <h4>Reference Configuration</h4>
    <p>Use the buttons above to clear, import, or export references.</p>
  </div>
</div>